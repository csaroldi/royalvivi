      "src": "data:image/svg+xml,%3Csvg%20xmlns=\"http://www.w3.org/2000/svg\"%20viewBox=\"0%200%20512%20512\"%3E%3Cdefs%3E%3ClinearGradient%20id=\"bg\"%20x1=\"0%\"%20y1=\"0%\"%20x2=\"0%\"%20y2=\"100%\"%3E%3Cstop%20offset=\"0%\"%20stop-color=\"#B76E79\"/%3E%3Cstop%20offset=\"100%\"%20stop-color=\"#8a4f58\"/%3E%3C/linearGradient%3E%3CradialGradient%20id=\"vignette\"%20cx=\"50%\"%20cy=\"40%\"%20r=\"70%\"%3E%3Cstop%20offset=\"0%\"%20stop-color=\"#D4A0A7\"%20stop-opacity=\"0.45\"/%3E%3Cstop%20offset=\"100%\"%20stop-color=\"#D4A0A7\"%20stop-opacity=\"0\"/%3E%3C/radialGradient%3E%3C/defs%3E%3Crect%20width=\"512\"%20height=\"512\"%20rx=\"112\"%20fill=\"url(#bg)\"/%3E%3Crect%20width=\"512\"%20height=\"512\"%20rx=\"112\"%20fill=\"url(#vignette)\"/%3E%3C%21--%20Wordmark:%20italic%20serif%20\"Vivi\",%20cream.%20Hand-drawn%20paths%20so%20it%20renders%20identically%20on%20every%20device.%20--%3E%3C%21--%20The%20second%20i%20(position%204)%20has%20its%20tittle%20replaced%20with%20a%20crown.%20--%3E%3Cg%20fill=\"#FDF8F3\"%3E%3C%21--%20V%20(wider%20italic%20V%20with%20thick%20left%20stroke%20and%20thin%20right%20stroke,%20dark%20rose%20kerning)%20--%3E%3Cpath%20d=\"%20M%2076%20180%20C%2088%20180,%2098%20184,%20104%20200%20L%20156%20338%20C%20160%20348,%20164%20352,%20170%20352%20L%20158%20366%20C%20146%20366,%20138%20356,%20132%20340%20L%2080%20206%20C%2076%20196,%2070%20188,%2062%20184%20Z%20M%20208%20180%20L%20220%20180%20C%20214%20184,%20208%20192,%20202%20206%20L%20158%20316%20C%20156%20322,%20155%20328,%20154%20332%20L%20146%20330%20L%20192%20208%20C%20198%20192,%20204%20184,%20208%20180%20Z%20\"/%3E%3C%21--%20First%20i%20(at%20around%20x=230):%20body%20as%20vertical%20bar%20with%20italic%20slant,%20round%20tittle%20--%3E%3Cpath%20d=\"%20M%20232%20224%20L%20248%20220%20L%20232%20334%20C%20231%20340,%20230%20346,%20232%20348%20L%20220%20352%20C%20218%20348,%20220%20340,%20221%20334%20Z%20\"/%3E%3Ccircle%20cx=\"247\"%20cy=\"198\"%20r=\"9\"/%3E%3C%21--%20v%20(lowercase%20v,%20cursive%20sweep)%20--%3E%3Cpath%20d=\"%20M%20272%20224%20C%20280%20224,%20286%20228,%20290%20240%20L%20318%20318%20L%20350%20240%20C%20354%20230,%20360%20224,%20366%20224%20L%20366%20232%20C%20360%20234,%20356%20240,%20352%20250%20L%20322%20334%20C%20320%20338,%20318%20340,%20316%20340%20C%20314%20340,%20312%20338,%20310%20334%20L%20280%20250%20C%20276%20240,%20272%20234,%20268%20232%20Z%20\"/%3E%3C%21--%20Second%20i%20body.%20NO%20tittle%20here%20-%20the%20crown%20replaces%20it.%20--%3E%3Cpath%20d=\"%20M%20388%20224%20L%20404%20220%20L%20388%20334%20C%20387%20340,%20386%20346,%20388%20348%20L%20376%20352%20C%20374%20348,%20376%20340,%20377%20334%20Z%20\"/%3E%3C/g%3E%3C%21--%20Crown%20sitting%20where%20the%20tittle%20on%20the%20second%20i%20would%20be.%20Gold,%20three%20points,%20with%20pearl%20tips%20and%20a%20rose%20jewel%20at%20the%20centre.%20--%3E%3C%21--%20Anchored%20around%20x=398%20(top%20of%20the%20second%20i),%20y=192%20--%3E%3Cg%3E%3C%21--%20Base%20band%20of%20the%20crown%20--%3E%3Crect%20x=\"372\"%20y=\"186\"%20width=\"52\"%20height=\"8\"%20rx=\"1\"%20fill=\"#C9A96E\"/%3E%3C%21--%20Three%20tiny%20points%20--%3E%3Cpath%20d=\"M%20376%20186%20L%20384%20166%20L%20392%20186%20Z\"%20fill=\"#C9A96E\"/%3E%3Cpath%20d=\"M%20394%20186%20L%20402%20158%20L%20410%20186%20Z\"%20fill=\"#C9A96E\"/%3E%3Cpath%20d=\"M%20412%20186%20L%20420%20166%20L%20428%20186%20Z\"%20fill=\"#C9A96E\"/%3E%3C%21--%20Pearl%20tips%20--%3E%3Ccircle%20cx=\"384\"%20cy=\"163\"%20r=\"3.5\"%20fill=\"#E8D5B0\"/%3E%3Ccircle%20cx=\"402\"%20cy=\"155\"%20r=\"4\"%20fill=\"#E8D5B0\"/%3E%3Ccircle%20cx=\"420\"%20cy=\"163\"%20r=\"3.5\"%20fill=\"#E8D5B0\"/%3E%3C%21--%20Centre%20jewel,%20rose%20--%3E%3Ccircle%20cx=\"398\"%20cy=\"190\"%20r=\"2.5\"%20fill=\"#B76E79\"/%3E%3C/g%3E%3C%21--%20Thin%20gold%20rule%20below%20the%20wordmark,%20echoing%20the%20cover%20--%3E%3Crect%20x=\"196\"%20y=\"400\"%20width=\"120\"%20height=\"2\"%20fill=\"#C9A96E\"%20opacity=\"0.7\"/%3E%3C/svg%3E",
